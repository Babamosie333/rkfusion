# Base URL of your backend API
VITE_API_URL=http://localhost:5000/api

# Your site's real, live domain (no trailing slash). Used in SEO meta tags
# (canonical link, Open Graph/Twitter previews, structured data). Vite
# injects this into index.html at build time - if you change it, you must
# rebuild/redeploy for the new value to take effect.
VITE_SITE_URL=https://rkfusion.com

# The WhatsApp number that receives Contact form messages.
# Use full international format with NO + sign, NO spaces, NO dashes.
# Example for an Indian number +91 98765 43210 -> 919876543210
VITE_WHATSAPP_NUMBER=919999999999

# The hidden path to the admin login. Change this to something only you know
# before deploying, e.g. /rk-portal-7x2k. Do not link this anywhere on the site.
VITE_ADMIN_PATH=/rk-admin-portal
m