# Local dev port (unused on Vercel - it assigns this automatically)
PORT=5000

# MongoDB connection string (MongoDB Atlas recommended - it's free and Vercel
# can reach it from anywhere, unlike a database on your own computer)
# Example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/rk-fusion
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/rk-fusion

# Secret used to sign admin JWT tokens - change this to a long random string
JWT_SECRET=change_this_to_a_long_random_string

# How long an admin login session stays valid
JWT_EXPIRES_IN=7d

# Credentials used ONLY by utils/createAdmin.js to seed your first admin account.
# Run "npm run seed:admin" once locally (pointed at your real MONGO_URI), then
# you don't need these in production.
ADMIN_SEED_EMAIL=admin@rkfusion.com
ADMIN_SEED_PASSWORD=change_this_password

# Comma separated list of origins allowed to call this API
# (your live Vercel client URL + your local dev URL)
CLIENT_ORIGIN=http://localhost:5173

# Cloudinary - free account at cloudinary.com. Used to store uploaded photos
# and videos, since Vercel's serverless functions have no persistent disk.
# Find these three values on your Cloudinary dashboard home page.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
